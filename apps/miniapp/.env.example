# Public origins generated into gitignored miniprogram/config.js.
# The API origin must be on the request-domain allowlist.
MINIAPP_API_BASE_URL=https://your-api-domain.example

# The web origin must be configured as a WeChat Mini Program business domain.
MINIAPP_WEB_BASE_URL=https://your-web-domain.example

# Synced into gitignored project.private.config.json. The AppSecret stays on the
# API only as WECHAT_MINI_PROGRAM_APP_SECRET.
MINIAPP_APP_ID=
