# Local API env. Copy to apps/api/.env for `make dev`.
#   cp apps/api/.env.example apps/api/.env

# Postgres. Matches the docker compose defaults; point at any reachable DB.
DATABASE_URL=postgres://wayfare:wayfare@localhost:5432/wayfare

# Better Auth. Secret must be >= 32 chars (dev value below is fine locally).
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef
BETTER_AUTH_URL=http://localhost:8787

# Origins allowed to call the API (the Vite dev server).
TRUSTED_ORIGINS=http://localhost:5173

# Port the API listens on (Vite proxies /api here).
PORT=8787
