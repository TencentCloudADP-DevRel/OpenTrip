# Production MySQL origin for Hyperdrive. Copy to a local (gitignored) env file
# or export in your shell — never commit real values.
#
# Required for: wrangler hyperdrive create / update

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# Build connection string:
#   mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}
#
# Create Hyperdrive (origin must be reachable from Cloudflare; password must work):
#   npx wrangler hyperdrive create opentrip-db \
#     --connection-string "mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}"
#
# Then write the id into wrangler and commit only the id (not credentials):
#   node deploy/cloudflare/scripts/set-hyperdrive.mjs <id>
#
# Rotate password later (no code change required):
#   npx wrangler hyperdrive update <id> \
#     --connection-string "mysql://..."
